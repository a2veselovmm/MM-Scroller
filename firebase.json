{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".git",
      ".git/**",
      ".vercel/**",
      ".firebase/**",
      ".agents/**",
      ".firebaserc",
      ".gitignore",
      ".gitattributes",
      "README.md",
      "vercel.json",
      "skills-lock.json",
      "server/api/**",
      "server/worker/**",
      "server/scripts/**",
      "server/README.md",
      "server/firestore.rules",
      "cloudbuild.yaml",
      "firebase-config.json"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin"
          },
          {
            "key": "Cross-Origin-Embedder-Policy",
            "value": "require-corp"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "mm-scroller-api",
          "region": "us-central1"
        }
      }
    ]
  }
}
